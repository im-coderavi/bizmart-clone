# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/digital_marketplace

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=30d

# Default admin (used by seed)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@blizmatt.com
ADMIN_PASSWORD=admin123

# Email (optional - if blank, emails are logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Digital Marketplace <no-reply@marketplace.com>"

# Razorpay (optional - mock checkout used if blank)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
